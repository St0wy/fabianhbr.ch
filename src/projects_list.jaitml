<?jai if projects.count > 0 { ?>
<h2>Projects</h2>
<div class="project-grid">
	<?jai for project: projects { ?>
	<a href="/projects/<?jai echo("%", project.slug); ?>" class="project-card">
		<img src="<?jai echo("%", project.hero_image); ?>" />
		<div class="project-info">
			<h3><?jai echo("%", project.title); ?></h3>
			<p><?jai echo("%", project.description); ?></p>
		</div>
	</a>
	<?jai } ?>
</div>
<?jai } ?>
