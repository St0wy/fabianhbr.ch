<?jai
Post :: struct {
	title: string;
	description: string;
	url: string;
}
posts: [..] Post;

?>
<rss version="2.0">
	<channel>
		<title>Stowy's Blog</title>
		<link>https://fabianhbr.ch</link>
		<description>Blog of Stowy aka Fabian</description>
		<?jai for posts { ?>
			<item>
				<title><?jai echo("%", it.title); ?></title>
				<description><?jai echo("%", it.description); ?></description>
				<guid><?jai echo("%", it.url); ?></guid>
			</item>
		<?jai } ?>
	</channel>
</rss>
